{
  "name": "@tome888/tauth-express",
  "version": "0.0.3",
  "description": "Flexible, type-safe JWT auth middleware for Express with dynamic keys and cookie support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "jwt",
    "authentication",
    "typescript",
    "middleware",
    "cookie-auth"
  ],
  "author": "Tome",
  "license": "MIT",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "express": "^4.19.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "cookie-parser": "^1.4.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  }
}
