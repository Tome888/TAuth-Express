{
  "name": "@tome888/tauth-express",
  "version": "0.0.1",
  "description": "Auth middleware for Express",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
